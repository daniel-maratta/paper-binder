root = true

[*.{cs,csproj,sln,md,json,ts,tsx,js,jsx,css,html,yml,yaml,ps1}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.cs]
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.ps1]
indent_style = space
indent_size = 2
