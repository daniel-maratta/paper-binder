# PostgreSQL container baseline
POSTGRES_DB=paperbinder
POSTGRES_USER=paperbinder
POSTGRES_PASSWORD=paperbinder_local_password

# Backend runtime configuration
PAPERBINDER_DB_CONNECTION=Host=localhost;Port=5432;Database=paperbinder;Username=paperbinder;Password=paperbinder_local_password
PAPERBINDER_PUBLIC_ROOT_URL=http://paperbinder.localhost:8080
PAPERBINDER_AUTH_COOKIE_DOMAIN=.paperbinder.localhost
PAPERBINDER_AUTH_COOKIE_NAME=paperbinder.auth
PAPERBINDER_AUTH_KEY_RING_PATH=paperbinder-local-keys
PAPERBINDER_CHALLENGE_SITE_KEY=local-demo-site-key
PAPERBINDER_CHALLENGE_SECRET_KEY=local-demo-secret-key
PAPERBINDER_LEASE_DEFAULT_MINUTES=60
PAPERBINDER_LEASE_EXTENSION_MINUTES=10
PAPERBINDER_LEASE_MAX_EXTENSIONS=3
PAPERBINDER_LEASE_CLEANUP_INTERVAL_SECONDS=60
PAPERBINDER_RATE_LIMIT_PREAUTH_PER_MINUTE=30
PAPERBINDER_RATE_LIMIT_AUTHENTICATED_PER_MINUTE=120
PAPERBINDER_RATE_LIMIT_LEASE_EXTEND_PER_MINUTE=10
PAPERBINDER_AUDIT_RETENTION_MODE=RetainTenantPurgedSummary
# PAPERBINDER_OTEL_OTLP_ENDPOINT=http://localhost:4317

# Frontend build-time configuration
VITE_PAPERBINDER_ROOT_URL=http://paperbinder.localhost:8080
VITE_PAPERBINDER_API_BASE_URL=http://paperbinder.localhost:8080
VITE_PAPERBINDER_TENANT_BASE_DOMAIN=paperbinder.localhost:8080
